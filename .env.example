# Expo CI Doctor - Environment Variables

# API URL for license verification (Defaults to https://expocidoctor.dev)
EXPO_CI_DOCTOR_API_URL="http://localhost:3000"

# License key for CI environments (bypasses login requirement)
EXPO_CI_DOCTOR_KEY="ecd_pro_..."

# Force verification, bypassing disk and memory caches (Set to 1)
EXPO_CI_DOCTOR_FORCE_VERIFY=1
