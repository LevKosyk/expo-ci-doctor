{
    "name": "expo-ci-doctor",
    "version": "1.0.1",
    "description": "Predicts Expo / React Native CI and EAS Build problems before you run the build",
    "type": "module",
    "main": "./dist/index.js",
    "bin": {
        "expo-ci-doctor": "./dist/index.js"
    },
    "files": [
        "dist/**",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "tsc && chmod +x ./dist/index.js",
        "postbuild": "chmod +x ./dist/index.js",
        "prepublishOnly": "npm run build"
    },
    "keywords": [
        "expo",
        "react-native",
        "eas",
        "ci",
        "build",
        "doctor",
        "cli",
        "diagnostics",
        "preflight",
        "github-actions"
    ],
    "license": "MIT",
    "publishConfig": {
        "access": "public"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "dependencies": {
        "boxen": "^8.0.1",
        "chalk": "^5.4.1",
        "cli-table3": "^0.6.5",
        "commander": "^12.1.0",
        "gradient-string": "^3.0.0",
        "inquirer": "^13.3.0",
        "ora": "^8.2.0",
        "semver": "^7.6.3"
    },
    "devDependencies": {
        "@types/gradient-string": "^1.1.6",
        "@types/inquirer": "^9.0.9",
        "@types/node": "^20.17.0",
        "@types/semver": "^7.5.8",
        "typescript": "^5.7.0"
    }
}